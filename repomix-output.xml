// ── Badge de estado ──────────────────────────────────────────────────────────
const ESTADO_BADGE = {
  en_espera:      { label: 'Esperando pago',  color: 'var(--gold)',         bg: 'rgba(224,168,48,0.12)'  },
  confirmado:     { label: 'Confirmado',       color: 'var(--accent-light)', bg: 'rgba(207,100,48,0.12)'  },
