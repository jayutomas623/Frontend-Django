          <span style={{ display: 'flex', alignItems: 'center', gap: 4, fontSize: 11, color: 'var(--gold)', background: 'rgba(224,168,48,0.1)', padding: '2px 8px', borderRadius: 10 }}>
            <Banknote size={10} /> Efectivo
