@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Jost:wght@300;400;500;600;700&display=swap');

/* ─── Paleta Kusillu — tierra, especia, selva ──────────────────────────── */
:root {
  /* Fondos cálidos (café espresso → mahogany) */
  --bg:        #0c0806;
  --surface:   #1a110b;
  --surface2:  #251710;
  --surface3:  #321f14;

  /* Bordes */
  --border:    #3a2218;
  --border-hi: #5a3422;

  /* Terracota — acento principal */
  --accent:     #cf6430;
  --accent-dim: #9e4a20;
  --accent-light: #e8855a;
  --accent-glow: rgba(207,100,48,0.18);

  /* Verde selva — acento secundario */
  --green:      #4a8b5c;
  --green-dim:  #366644;
  --green-glow: rgba(74,139,92,0.14);

  /* Oro/saffron — highlights */
  --gold:      #e0a830;
  --gold-dim:  #b07e1a;
  --gold-glow: rgba(224,168,48,0.16);

  /* Texto cálido */
  --text:       #f0e4d2;
  --text-muted: #8a7260;
  --text-dim:   #574030;

  /* Semáforo */
  --success:    #5ab87d;
  --success-bg: rgba(90,184,125,0.10);
  --warning:    #d4943a;
  --warning-bg: rgba(212,148,58,0.10);
  --danger:     #c95c5c;
  --danger-bg:  rgba(201,92,92,0.10);

  /* Radios */
  --radius:    12px;
  --radius-sm: 8px;
  --radius-xs: 6px;
}

/* ─── Reset ──────────────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body, #root {
  min-height: 100%;
  background: var(--bg);
}

body {
  font-family: 'Jost', sans-serif;
  background: var(--bg);
  color: var(--text);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ─── Tipografía ─────────────────────────────────────────────────────────── */
h1, h2, h3, h4 {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 600;
  line-height: 1.18;
  letter-spacing: -0.01em;
}

/* ─── Formularios ────────────────────────────────────────────────────────── */
input, select, textarea {
  font-family: 'Jost', sans-serif;
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--text);
  border-radius: var(--radius-sm);
  padding: 11px 16px;
  font-size: 14px;
  width: 100%;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}
input::placeholder, textarea::placeholder { color: var(--text-dim); }
input:focus, select:focus, textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-glow);
}
select option { background: var(--surface2); color: var(--text); }

/* ─── Botones ────────────────────────────────────────────────────────────── */
button {
  font-family: 'Jost', sans-serif;
  cursor: pointer;
  border: none;
  border-radius: var(--radius-sm);
  font-size: 14px;
  font-weight: 500;
  transition: opacity 0.18s, transform 0.12s, box-shadow 0.18s;
}
button:disabled { opacity: 0.4; cursor: not-allowed; }
button:not(:disabled):active { transform: scale(0.97); }

/* ─── Links ──────────────────────────────────────────────────────────────── */
a { color: var(--accent-light); text-decoration: none; }
a:hover { text-decoration: underline; }

/* ─── Scrollbar ──────────────────────────────────────────────────────────── */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border-hi); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-dim); }

/* ─── Noise texture overlay ─────────────────────────────────────────────── */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
  opacity: 0.025;
  pointer-events: none;
  z-index: 9999;
}

/* ─── Animations ─────────────────────────────────────────────────────────── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.5; }
}
